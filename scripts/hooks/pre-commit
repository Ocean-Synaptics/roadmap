#!/bin/bash
# Pre-commit hook for governance enforcement
# 1. Branch discipline: reject head.json edits on main/master
# 2. Local validation gates: typecheck + DAG integrity
# Blocks commit if any gate fails
# Override with: git commit --no-verify

set -e

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}ūüĒć Pre-commit validation...${NC}"

# Get the project root
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Track failures
FAILED=0

# 0. Worktree Protocol: Branch discipline enforcement
echo -e "${YELLOW}  ‚ě§ Branch discipline...${NC}"
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || echo "")

if [ -n "$BRANCH" ] && [ -n "$STAGED_FILES" ]; then
  # Check if any staged files match head*.json pattern
  if echo "$STAGED_FILES" | grep -q '\.roadmap/head.*\.json'; then
    # Allow edits ONLY on feature/work branches and develop
    if [[ "$BRANCH" != "feat/"* ]] && [[ "$BRANCH" != "wip/"* ]] && [[ "$BRANCH" != "develop" ]]; then
      echo -e "${RED}  ‚úó Branch discipline violation${NC}"
      echo -e "${RED}‚ĚĆ ERROR: Cannot edit .roadmap/head*.json on branch '$BRANCH'${NC}"
      echo ""
      echo -e "${YELLOW}Worktree Protocol:${NC}"
      echo -e "   Only feat/*, wip/*, and develop branches may edit .roadmap/head*.json"
      echo -e "   Files locked on: main, master (read-only by design)"
      echo ""
      echo -e "${YELLOW}Fix:${NC}"
      echo -e "   1. git reset HEAD .roadmap/head*.json"
      echo -e "   2. roadmap spawn --task <node-id>"
      echo -e "   3. Edit in feature branch"
      echo ""
      FAILED=$((FAILED + 1))
    else
      echo -e "${GREEN}  ‚úď Branch discipline${NC}"
    fi
  else
    echo -e "${GREEN}  ‚úď Branch discipline${NC}"
  fi
else
  # Edge case: HEAD not available (early in repo) or no staged files
  echo -e "${GREEN}  ‚úď Branch discipline${NC}"
fi

# 1. TypeScript check
echo -e "${YELLOW}  ‚ě§ TypeScript compilation...${NC}"
if npm run check > /tmp/tsc.log 2>&1; then
  echo -e "${GREEN}  ‚úď TypeScript${NC}"
else
  echo -e "${RED}  ‚úó TypeScript errors:${NC}"
  cat /tmp/tsc.log | head -30
  FAILED=$((FAILED + 1))
fi

# 2. DAG structural integrity
echo -e "${YELLOW}  ‚ě§ DAG structure...${NC}"
if npm run check:dag:define > /tmp/dag.log 2>&1; then
  echo -e "${GREEN}  ‚úď DAG integrity${NC}"
else
  echo -e "${RED}  ‚úó DAG structural errors:${NC}"
  cat /tmp/dag.log | head -30
  FAILED=$((FAILED + 1))
fi

# Final result
echo ""
if [ $FAILED -eq 0 ]; then
  echo -e "${GREEN}‚úÖ All pre-commit gates passed${NC}"
  exit 0
else
  echo -e "${RED}‚ĚĆ Pre-commit validation failed ($FAILED gate(s))${NC}"
  echo -e "${YELLOW}ūüí° Fix the errors above and try again, or use:${NC}"
  echo -e "${YELLOW}   git commit --no-verify${NC} (governance override, use sparingly)"
  exit 1
fi
