{
  "id": "us1-gitsha-gov012",
  "desc": "US1 gitSha completion provenance + FR-GOV-012 env-var bypass elimination",
  "init": "init",
  "term": "term",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Existing codebase: completion-evidence.ts, protocol.ts validators, bin/roadmap.ts, CI workflow",
      "produces": [
        "src/lib/completion-evidence.ts",
        "src/protocol.ts",
        "bin/roadmap.ts",
        ".github/workflows/ci.yml"
      ],
      "consumes": [],
      "deps": [],
      "validate": [
        { "type": "artifact-exists", "target": "src/lib/completion-evidence.ts" },
        { "type": "artifact-exists", "target": "bin/roadmap.ts" }
      ],
      "idempotent": true
    },

    "rm-gitsha-interface": {
      "id": "rm-gitsha-interface",
      "desc": "US1: Add gitSha?: string to CompletionRecordWithEvidence interface. Emit gitSha in saveCompletionWithEvidence() using execSync('git rev-parse HEAD').",
      "produces": [
        "src/lib/completion-evidence.ts"
      ],
      "consumes": [
        "src/lib/completion-evidence.ts"
      ],
      "deps": ["init"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "npx vitest run tests/completion-gitsha.test.ts --reporter=dot" }
      ],
      "idempotent": true
    },

    "rm-gitsha-cli-emit": {
      "id": "rm-gitsha-cli-emit",
      "desc": "US1: Wire gitSha into cmdComplete and cmdCertify — pass current git SHA to saveCompletionWithEvidence(). Verify completed.json entries include gitSha after node completion.",
      "produces": [
        "bin/roadmap.ts",
        "tests/completion-gitsha.test.ts"
      ],
      "consumes": [
        "bin/roadmap.ts",
        "src/lib/completion-evidence.ts"
      ],
      "deps": ["rm-gitsha-interface"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "npx vitest run tests/completion-gitsha.test.ts --reporter=dot" }
      ],
      "idempotent": true
    },

    "rm-gitsha-ci-gate": {
      "id": "rm-gitsha-ci-gate",
      "desc": "US1: CI gate script scripts/ci/roadmap-gitsha-gate.ts — verify all completion records in completed.json have gitSha field. Wire into CI promote lane.",
      "produces": [
        "scripts/ci/roadmap-gitsha-gate.ts",
        ".github/workflows/ci.yml"
      ],
      "consumes": [
        "src/lib/completion-evidence.ts",
        ".github/workflows/ci.yml"
      ],
      "deps": ["rm-gitsha-cli-emit"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "grep -q 'roadmap-gitsha-gate' .github/workflows/ci.yml" }
      ],
      "idempotent": true
    },

    "rm-env-audit-script": {
      "id": "rm-env-audit-script",
      "desc": "FR-GOV-012: tools/audit-env-bypasses.ts — scan src/, bin/, scripts/, tests/ for process.env usage. Classify as bypass/config/test-harness. Exit 1 if any bypass keys outside tests/.",
      "produces": [
        "tools/audit-env-bypasses.ts"
      ],
      "consumes": [
        "bin/roadmap.ts",
        "src/protocol.ts"
      ],
      "deps": ["init"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "npx vitest run tests/env-audit.test.ts --reporter=dot" }
      ],
      "idempotent": true
    },

    "rm-remove-env-bypasses": {
      "id": "rm-remove-env-bypasses",
      "desc": "FR-GOV-012: Remove SKIP_PLAN_GATE env var from production paths (bin/roadmap.ts). Replace with --skip-plan-gate CLI flag that writes non-passing receipt. Replace ROADMAP_VALIDATING with internal ValidationContext parameter threaded through call stack.",
      "produces": [
        "bin/roadmap.ts",
        "src/protocol.ts"
      ],
      "consumes": [
        "bin/roadmap.ts",
        "src/protocol.ts",
        "tools/audit-env-bypasses.ts"
      ],
      "deps": ["rm-env-audit-script"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "npx vitest run tests/env-bypass-removal.test.ts --reporter=dot" },
        { "type": "shell", "command": "npx tsx tools/audit-env-bypasses.ts" }
      ],
      "idempotent": true
    },

    "rm-env-audit-ci": {
      "id": "rm-env-audit-ci",
      "desc": "FR-GOV-012: Wire tools/audit-env-bypasses.ts into CI as required check. Add SKIP_PLAN_GATE to the Reject SKIP_ bypass in CI step.",
      "produces": [
        ".github/workflows/ci.yml"
      ],
      "consumes": [
        ".github/workflows/ci.yml",
        "tools/audit-env-bypasses.ts"
      ],
      "deps": ["rm-remove-env-bypasses"],
      "validate": [
        { "type": "shell", "command": "grep -q 'audit-env-bypasses' .github/workflows/ci.yml" },
        { "type": "shell", "command": "grep -q 'SKIP_PLAN_GATE' .github/workflows/ci.yml" }
      ],
      "idempotent": true
    },

    "term": {
      "id": "term",
      "desc": "US1 gitSha provenance on completion records + FR-GOV-012 env-var bypass elimination — no governance decisions depend on ambient env vars",
      "produces": [],
      "consumes": [],
      "deps": ["rm-gitsha-ci-gate", "rm-env-audit-ci"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "npx vitest run --reporter=dot" }
      ],
      "idempotent": true
    }
  }
}
