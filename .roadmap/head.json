{
  "id": "fr-meta-refac-001-gen",
  "desc": "Refactoring execution: consolidate schemas, wrap CLI, split tests, move IO, perf validation",
  "init": "init-refactoring",
  "term": "intent-refactoring-complete",
  "nodes": {
    "init-refactoring": {
      "id": "init-refactoring",
      "desc": "Start refactoring work from metaspec synthesis",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "mode": "execute"
    },
    "consolidate-schema": {
      "id": "consolidate-schema",
      "desc": "Merge audit-schema.ts and perf-schema.ts into single src/lib/schema.ts (highest value: 50)",
      "produces": [
        "src/lib/schema.ts",
        ".audit/consolidate-schema.receipt.json"
      ],
      "consumes": [
        "src/lib/audit/audit-schema.ts",
        "src/lib/perf/perf-schema.ts"
      ],
      "deps": ["init-refactoring"],
      "validate": [
        { "type": "artifact-exists", "path": "src/lib/schema.ts" },
        { "type": "shell", "command": "test ! -f src/lib/audit/audit-schema.ts || grep -q 'deprecated' src/lib/audit/audit-schema.ts" },
        { "type": "shell", "command": "npm run test 2>&1 | grep -q 'passing'" }
      ],
      "mode": "execute"
    },
    "wrap-cli-audit": {
      "id": "wrap-cli-audit",
      "desc": "Add 'roadmap audit' command to CLI registry (value: 35)",
      "produces": [
        "src/cli/commands/audit.ts",
        ".audit/wrap-cli-audit.receipt.json"
      ],
      "consumes": [
        "bin/cli.ts",
        "src/lib/audit/audit-engine.ts"
      ],
      "deps": ["init-refactoring"],
      "validate": [
        { "type": "artifact-exists", "path": "src/cli/commands/audit.ts" },
        { "type": "shell", "command": "grep -q 'registerCommand.*audit' src/cli/commands/audit.ts" }
      ],
      "mode": "execute"
    },
    "split-integration-tests": {
      "id": "split-integration-tests",
      "desc": "Split slow integration tests into separate file (value: 30)",
      "produces": [
        "tests/integration-fast.test.ts",
        "tests/integration-slow.test.ts",
        ".audit/split-tests.receipt.json"
      ],
      "consumes": [
        "tests/integration.test.ts"
      ],
      "deps": ["init-refactoring"],
      "validate": [
        { "type": "artifact-exists", "path": "tests/integration-fast.test.ts" },
        { "type": "artifact-exists", "path": "tests/integration-slow.test.ts" },
        { "type": "shell", "command": "npm run test -- tests/integration-fast.test.ts --run 2>&1 | tail -5 | grep -q 'passing'" }
      ],
      "mode": "execute"
    },
    "move-io-purity": {
      "id": "move-io-purity",
      "desc": "Move IO imports from src/lib to src/io to preserve lib purity (value: 28)",
      "produces": [
        "src/io/",
        ".audit/move-io.receipt.json"
      ],
      "consumes": [
        "src/lib/audit/audit-engine.ts"
      ],
      "deps": ["init-refactoring"],
      "validate": [
        { "type": "shell", "command": "! grep -r 'require.*fs\\|import.*fs' src/lib --include='*.ts'" }
      ],
      "mode": "execute"
    },
    "wrap-cli-expand": {
      "id": "wrap-cli-expand",
      "desc": "Add 'roadmap expand' CLI wrapper for scripts (value: 22)",
      "produces": [
        "src/cli/commands/expand.ts",
        ".audit/wrap-cli-expand.receipt.json"
      ],
      "consumes": [
        "bin/cli.ts",
        "scripts/expand-*.ts"
      ],
      "deps": ["init-refactoring"],
      "validate": [
        { "type": "artifact-exists", "path": "src/cli/commands/expand.ts" },
        { "type": "shell", "command": "grep -q 'expandScript' src/cli/commands/expand.ts" }
      ],
      "mode": "execute"
    },
    "intent-refactoring-complete": {
      "id": "intent-refactoring-complete",
      "desc": "Terminal: all refactorings complete, tests pass, vitest <15s, imports verified",
      "produces": [
        ".audit/intent-refactoring-complete.receipt.json"
      ],
      "consumes": [
        ".audit/consolidate-schema.receipt.json",
        ".audit/wrap-cli-audit.receipt.json",
        ".audit/split-tests.receipt.json",
        ".audit/move-io.receipt.json",
        ".audit/wrap-cli-expand.receipt.json"
      ],
      "deps": [
        "consolidate-schema",
        "wrap-cli-audit",
        "split-integration-tests",
        "move-io-purity",
        "wrap-cli-expand"
      ],
      "validate": [
        { "type": "shell", "command": "npm run test 2>&1 | grep -q 'passing'" },
        { "type": "shell", "command": "! grep -r 'audit-schema\\|perf-schema' src/lib/audit src/lib/perf --include='*.ts' 2>/dev/null | grep -v deprecated" },
        { "type": "shell", "command": "npm run build 2>&1 | grep -q 'successful\\|Build complete' || npm run tsc 2>&1 | tail -1 | grep -q 'successfully'" }
      ],
      "mode": "plan"
    }
  }
}
