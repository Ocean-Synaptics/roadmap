{
  "id": "fr-meta-evid-001",
  "desc": "Evidence-Required Output + Anti-Hallucination Gates (kernel-level governance)",
  "init": "init-governance",
  "term": "intent-evidence-kernel-active",
  "nodes": {
    "init-governance": {
      "id": "init-governance",
      "desc": "Current state: metaspec/metaloop produce claims without evidence backing (blocker fixed)",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "mode": "execute"
    },
    "evidence-schema": {
      "id": "evidence-schema",
      "desc": "Define EVIDENCE.json contract: schema_version, headSha, diffstat, reads, checks, git provenance",
      "produces": [
        "src/lib/evidence/schema.ts",
        "docs/evidence/EVIDENCE_CONTRACT.md"
      ],
      "consumes": [],
      "deps": ["init-governance"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/evidence/schema.ts"},
        {"type": "artifact-exists", "path": "docs/evidence/EVIDENCE_CONTRACT.md"}
      ],
      "mode": "execute"
    },
    "evidence-collector": {
      "id": "evidence-collector",
      "desc": "Implement collectEvidence(repoRoot, before, after, readPaths): git diff + file reads + test results",
      "produces": [
        "src/lib/evidence/collect.ts",
        "tests/evidence/collect.test.ts"
      ],
      "consumes": [
        "src/lib/evidence/schema.ts"
      ],
      "deps": ["evidence-schema"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/evidence/collect.ts"},
        {"type": "shell", "command": "npm run test -- tests/evidence/collect.test.ts --run 2>&1 | grep -q 'pass'"}
      ],
      "mode": "execute"
    },
    "claim-renderer": {
      "id": "claim-renderer",
      "desc": "Implement ClaimRenderer: refuses to emit summaries without evidence. Enforces EVIDENCE_REQUIRED, INSUFFICIENT_READ_PROOFS, STUB_ONLY_CHANGESET",
      "produces": [
        "src/lib/claims/render.ts",
        "src/lib/claims/detectors.ts",
        "tests/claims/render.test.ts"
      ],
      "consumes": [
        "src/lib/evidence/schema.ts"
      ],
      "deps": ["evidence-schema"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/claims/render.ts"},
        {"type": "artifact-exists", "path": "src/lib/claims/detectors.ts"},
        {"type": "shell", "command": "npm run test -- tests/claims/ --run 2>&1 | grep -q 'pass'"}
      ],
      "mode": "execute"
    },
    "metaloop-evidence-wiring": {
      "id": "metaloop-evidence-wiring",
      "desc": "Wire metaloop runner: collect evidence at end of each iteration, call claim renderer, emit only renderer output",
      "produces": [
        "src/lib/metaloop/evidence-integration.ts"
      ],
      "consumes": [
        "src/lib/evidence/collect.ts",
        "src/lib/claims/render.ts"
      ],
      "deps": ["evidence-collector", "claim-renderer"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/metaloop/evidence-integration.ts"}
      ],
      "mode": "execute"
    },
    "roadmap-verify-invariant": {
      "id": "roadmap-verify-invariant",
      "desc": "Add kernel invariant: metaloop_evidence_required. For each .roadmap/metaloop/runs/*/ITERATIONS/it-*/DECISION.json, require sibling evidence/EVIDENCE.json + receipts/CLAIM.json",
      "produces": [
        "src/lib/validation/invariants/metaloop-evidence.ts"
      ],
      "consumes": [],
      "deps": ["evidence-collector"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/validation/invariants/metaloop-evidence.ts"},
        {"type": "shell", "command": "npm run test -- tests/validation/invariants/ --run 2>&1 | grep -q 'pass'"}
      ],
      "mode": "execute"
    },
    "terminal-intent-evidence-binding": {
      "id": "terminal-intent-evidence-binding",
      "desc": "Terminal intent gates must cite evidence bundle path, headSha before/after, diffstat. Unevaluated without evidence.",
      "produces": [
        "src/lib/intent/evidence-context.ts",
        "docs/INTENT_EVIDENCE_BINDING.md"
      ],
      "consumes": [
        "src/lib/evidence/schema.ts"
      ],
      "deps": ["evidence-schema"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/intent/evidence-context.ts"},
        {"type": "artifact-exists", "path": "docs/INTENT_EVIDENCE_BINDING.md"}
      ],
      "mode": "execute"
    },
    "intent-evidence-kernel-active": {
      "id": "intent-evidence-kernel-active",
      "desc": "Terminal: Evidence-required enforcement active. Any claim without evidence backing → BLOCKED. Metaspec/metaloop cannot produce hallucinated summaries.",
      "produces": [
        ".roadmap/evidence-kernel-ACTIVE.receipt.json"
      ],
      "consumes": [
        "src/lib/evidence/collect.ts",
        "src/lib/claims/render.ts",
        "src/lib/metaloop/evidence-integration.ts",
        "src/lib/validation/invariants/metaloop-evidence.ts",
        "src/lib/intent/evidence-context.ts"
      ],
      "deps": ["metaloop-evidence-wiring", "roadmap-verify-invariant", "terminal-intent-evidence-binding"],
      "validate": [
        {"type": "artifact-exists", "path": ".roadmap/evidence-kernel-ACTIVE.receipt.json"},
        {"type": "shell", "command": "npm run test -- tests/evidence tests/claims tests/validation/invariants --run 2>&1 | grep -q 'pass'"}
      ],
      "mode": "plan"
    }
  }
}
