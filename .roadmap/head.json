{
  "id": "fr-meta-refac-001",
  "desc": "Refactor Survey Swarm → Fan-in Analysis → Next Spec-kit Run",
  "init": "refac-run-bootstrap",
  "term": "intent-refac-pipeline",
  "nodes": {
    "refac-run-bootstrap": {
      "id": "refac-run-bootstrap",
      "desc": "Initialize refactor survey run directory, record baseline metadata (repo HEAD, tool versions, agent roster)",
      "produces": [
        ".audit/refactor-runs/<runId>/RUN.json",
        ".audit/refactor-runs/<runId>/agents/AGENTS.json"
      ],
      "consumes": [],
      "deps": [],
      "validate": [
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/RUN.json" },
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/agents/AGENTS.json" },
        { "type": "artifact-schema", "path": ".audit/refactor-runs/<runId>/RUN.json", "schema": "repo.headSha, rankingWeights" }
      ],
      "mode": "execute"
    },
    "refac-survey-plan": {
      "id": "refac-survey-plan",
      "desc": "Plan node for parallel survey agents. Expands into refac-survey-agent-01..N.",
      "produces": [],
      "consumes": [".audit/refactor-runs/<runId>/RUN.json", ".audit/refactor-runs/<runId>/agents/AGENTS.json"],
      "deps": ["refac-run-bootstrap"],
      "validate": [{ "type": "expanded", "minNodes": 3 }],
      "mode": "plan"
    },
    "refac-survey-agent-01": {
      "id": "refac-survey-agent-01",
      "desc": "Scan scope: src/lib, src/protocol, src/agent. Produce structured receipt with evidence.",
      "produces": [".audit/refactor-runs/<runId>/agents/survey-01.receipt.json"],
      "consumes": [".audit/refactor-runs/<runId>/agents/AGENTS.json"],
      "deps": ["refac-survey-plan"],
      "validate": [
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/agents/survey-01.receipt.json" },
        { "type": "artifact-schema", "path": ".audit/refactor-runs/<runId>/agents/survey-01.receipt.json", "schema": "agentId, findings[]" },
        { "type": "shell", "command": "jq '.findings | length > 0' .audit/refactor-runs/<runId>/agents/survey-01.receipt.json" }
      ],
      "mode": "execute",
      "expandedFrom": "refac-survey-plan"
    },
    "refac-survey-agent-02": {
      "id": "refac-survey-agent-02",
      "desc": "Scan scope: bin/, tests/. Produce structured receipt with evidence.",
      "produces": [".audit/refactor-runs/<runId>/agents/survey-02.receipt.json"],
      "consumes": [".audit/refactor-runs/<runId>/agents/AGENTS.json"],
      "deps": ["refac-survey-plan"],
      "validate": [
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/agents/survey-02.receipt.json" },
        { "type": "artifact-schema", "path": ".audit/refactor-runs/<runId>/agents/survey-02.receipt.json", "schema": "agentId, findings[]" },
        { "type": "shell", "command": "jq '.findings | length > 0' .audit/refactor-runs/<runId>/agents/survey-02.receipt.json" }
      ],
      "mode": "execute",
      "expandedFrom": "refac-survey-plan"
    },
    "refac-survey-agent-03": {
      "id": "refac-survey-agent-03",
      "desc": "Scan scope: docs/, scripts/. Produce structured receipt with evidence.",
      "produces": [".audit/refactor-runs/<runId>/agents/survey-03.receipt.json"],
      "consumes": [".audit/refactor-runs/<runId>/agents/AGENTS.json"],
      "deps": ["refac-survey-plan"],
      "validate": [
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/agents/survey-03.receipt.json" },
        { "type": "artifact-schema", "path": ".audit/refactor-runs/<runId>/agents/survey-03.receipt.json", "schema": "agentId, findings[]" },
        { "type": "shell", "command": "jq '.findings | length > 0' .audit/refactor-runs/<runId>/agents/survey-03.receipt.json" }
      ],
      "mode": "execute",
      "expandedFrom": "refac-survey-plan"
    },
    "refac-fan-in-synthesis": {
      "id": "refac-fan-in-synthesis",
      "desc": "Deterministically merge receipts. Cluster, rank, detect conflicts. Produce SYNTHESIS.json.",
      "produces": [".audit/refactor-runs/<runId>/fan-in/SYNTHESIS.json", ".audit/refactor-runs/<runId>/fan-in/SYNTHESIS.md"],
      "consumes": [
        ".audit/refactor-runs/<runId>/agents/survey-01.receipt.json",
        ".audit/refactor-runs/<runId>/agents/survey-02.receipt.json",
        ".audit/refactor-runs/<runId>/agents/survey-03.receipt.json"
      ],
      "deps": ["refac-survey-agent-01", "refac-survey-agent-02", "refac-survey-agent-03"],
      "validate": [
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/fan-in/SYNTHESIS.json" },
        { "type": "shell", "command": "jq '.clusters | length > 0' .audit/refactor-runs/<runId>/fan-in/SYNTHESIS.json" }
      ],
      "mode": "execute"
    },
    "refac-specgen": {
      "id": "refac-specgen",
      "desc": "Generate next spec-kit from synthesis. Produce SPEC.md, TASKS.md, PLAN.md, GALLERY.json, SELECTED.json.",
      "produces": [
        ".specify/<specId>/SPEC.md",
        ".specify/<specId>/TASKS.md",
        ".specify/<specId>/PLAN.md",
        ".specify/<specId>/GALLERY.json",
        ".specify/<specId>/SELECTED.json"
      ],
      "consumes": [
        ".audit/refactor-runs/<runId>/fan-in/SYNTHESIS.json",
        ".audit/refactor-runs/<runId>/fan-in/SYNTHESIS.md"
      ],
      "deps": ["refac-fan-in-synthesis"],
      "validate": [
        { "type": "artifact-exists", "path": ".specify/<specId>/SPEC.md" },
        { "type": "artifact-exists", "path": ".specify/<specId>/TASKS.md" },
        { "type": "artifact-exists", "path": ".specify/<specId>/GALLERY.json" },
        { "type": "shell", "command": "grep -q 'intent-init\\|intent-term\\|mine-run\\|audit-surface\\|perf-budget' .specify/<specId>/TASKS.md" },
        { "type": "shell", "command": "jq '.strategies | length >= 2' .specify/<specId>/GALLERY.json" }
      ],
      "mode": "execute"
    },
    "intent-refac-pipeline": {
      "id": "intent-refac-pipeline",
      "desc": "Terminal intent gate. Verify governance-complete: spec coherence, DAG acyclic, all validators, gates present.",
      "produces": [".audit/refactor-runs/<runId>/RECEIPT.json"],
      "consumes": [
        ".specify/<specId>/SPEC.md",
        ".specify/<specId>/TASKS.md",
        ".specify/<specId>/PLAN.md",
        ".specify/<specId>/GALLERY.json",
        ".specify/<specId>/SELECTED.json"
      ],
      "deps": ["refac-specgen"],
      "validate": [
        { "type": "artifact-exists", "path": ".audit/refactor-runs/<runId>/RECEIPT.json" },
        { "type": "artifact-schema", "path": ".audit/refactor-runs/<runId>/RECEIPT.json", "schema": "verdict, gatePasses" }
      ],
      "mode": "execute"
    }
  }
}
