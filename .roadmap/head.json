{
  "id": "chatelet-p4",
  "desc": "Phase 4: Châtelet Architecture — Keep/Packs Separation",
  "protocolVersion": "1.0.0",
  "version": "1.0",
  "init": "p4-init",
  "term": "p4-chatelet-complete",
  "spec": ".specify/specs/fr-chatelet-001/spec.md",
  "nodes": {
    "p4-init": {
      "id": "p4-init",
      "desc": "Phase 4 init — Châtelet architecture kickoff",
      "produces": ["p4-init.marker"],
      "consumes": [".roadmap/metaflow/p3-synthesis-complete.json"],
      "deps": [],
      "validate": [{"type": "artifact-exists", "target": "p4-init.marker"}],
      "idempotent": true
    },
    "p4-init-chatelet": {
      "id": "p4-init-chatelet",
      "desc": "Create CHATELET.json + .chatelet/ infrastructure",
      "produces": ["security/CHATELET.json", ".chatelet/README.md"],
      "consumes": ["p4-init.marker"],
      "deps": ["p4-init"],
      "validate": [{"type": "artifact-exists", "target": "security/CHATELET.json"}],
      "idempotent": true
    },
    "p4-audit-monolith": {
      "id": "p4-audit-monolith",
      "desc": "Audit current src/ — identify keep vs. pack candidates",
      "produces": [".chatelet/monolith-audit.json"],
      "consumes": ["p4-init.marker"],
      "deps": ["p4-init"],
      "validate": [{"type": "artifact-exists", "target": ".chatelet/monolith-audit.json"}],
      "idempotent": true
    },
    "p4-gitsafe-primitives": {
      "id": "p4-gitsafe-primitives",
      "desc": "Implement gitSafe module (listRefs, readBlob, readJson, lsTree, diffPaths)",
      "produces": ["src/lib/gitsafe/index.ts"],
      "consumes": ["p4-init.marker"],
      "deps": ["p4-init"],
      "validate": [{"type": "artifact-exists", "target": "src/lib/gitsafe/index.ts"}],
      "idempotent": true
    },
    "p4-gitsafe-contract": {
      "id": "p4-gitsafe-contract",
      "desc": "Unit tests for gitSafe bounds + denylist",
      "produces": ["src/lib/gitsafe/__tests__/contract.test.ts"],
      "consumes": ["p4-gitsafe-primitives"],
      "deps": ["p4-gitsafe-primitives"],
      "validate": [{"type": "artifact-exists", "target": "src/lib/gitsafe/__tests__/contract.test.ts"}],
      "idempotent": true
    },
    "p4-keepbudget-config": {
      "id": "p4-keepbudget-config",
      "desc": "CHATELET.json validator + KeepBudget enforcement",
      "produces": ["src/lib/chatelet/keepbudget.ts"],
      "consumes": ["p4-init-chatelet"],
      "deps": ["p4-init-chatelet"],
      "validate": [{"type": "artifact-exists", "target": "src/lib/chatelet/keepbudget.ts"}],
      "idempotent": true
    },
    "p4-chatelet-status": {
      "id": "p4-chatelet-status",
      "desc": "Implement `tool chatelet status` command",
      "produces": ["src/cli/commands/chatelet-status.ts"],
      "consumes": ["p4-gitsafe-primitives", "p4-keepbudget-config"],
      "deps": ["p4-gitsafe-primitives", "p4-keepbudget-config"],
      "validate": [{"type": "artifact-exists", "target": "src/cli/commands/chatelet-status.ts"}],
      "idempotent": true
    },
    "p4-packs-list": {
      "id": "p4-packs-list",
      "desc": "Implement `tool packs list` command (deterministic discovery)",
      "produces": ["src/cli/commands/packs-list.ts"],
      "consumes": ["p4-gitsafe-primitives"],
      "deps": ["p4-gitsafe-primitives"],
      "validate": [{"type": "artifact-exists", "target": "src/cli/commands/packs-list.ts"}],
      "idempotent": true
    },
    "p4-packs-show": {
      "id": "p4-packs-show",
      "desc": "Implement `tool packs show <name>` command",
      "produces": ["src/cli/commands/packs-show.ts"],
      "consumes": ["p4-gitsafe-primitives"],
      "deps": ["p4-gitsafe-primitives"],
      "validate": [{"type": "artifact-exists", "target": "src/cli/commands/packs-show.ts"}],
      "idempotent": true
    },
    "p4-packs-extract": {
      "id": "p4-packs-extract",
      "desc": "Implement `tool packs extract` command (bounded reads)",
      "produces": ["src/cli/commands/packs-extract.ts"],
      "consumes": ["p4-gitsafe-primitives"],
      "deps": ["p4-gitsafe-primitives"],
      "validate": [{"type": "artifact-exists", "target": "src/cli/commands/packs-extract.ts"}],
      "idempotent": true
    },
    "p4-ci-gate-keep": {
      "id": "p4-ci-gate-keep",
      "desc": "CI gate: chatelet-keep (blocks main violations)",
      "produces": [".github/workflows/gate-chatelet-keep.yml"],
      "consumes": ["p4-chatelet-status"],
      "deps": ["p4-chatelet-status"],
      "validate": [{"type": "artifact-exists", "target": ".github/workflows/gate-chatelet-keep.yml"}],
      "idempotent": true
    },
    "p4-ci-gate-manifests": {
      "id": "p4-ci-gate-manifests",
      "desc": "CI gate: pack-manifests validation",
      "produces": [".github/workflows/gate-pack-manifests.yml"],
      "consumes": ["p4-packs-show"],
      "deps": ["p4-packs-show"],
      "validate": [{"type": "artifact-exists", "target": ".github/workflows/gate-pack-manifests.yml"}],
      "idempotent": true
    },
    "p4-migration-planner": {
      "id": "p4-migration-planner",
      "desc": "Implement `tool chatelet migrate --plan-only`",
      "produces": ["src/cli/commands/chatelet-migrate.ts"],
      "consumes": ["p4-audit-monolith", "p4-chatelet-status"],
      "deps": ["p4-audit-monolith", "p4-chatelet-status"],
      "validate": [{"type": "artifact-exists", "target": "src/cli/commands/chatelet-migrate.ts"}],
      "idempotent": true
    },
    "p4-pack-core-stub": {
      "id": "p4-pack-core-stub",
      "desc": "Create packs/core branch with PACK.json",
      "produces": ["packs/core/PACK.json"],
      "consumes": ["p4-migration-planner"],
      "deps": ["p4-migration-planner"],
      "validate": [{"type": "artifact-exists", "target": "packs/core/PACK.json"}],
      "idempotent": true
    },
    "p4-keep-refactor-stub": {
      "id": "p4-keep-refactor-stub",
      "desc": "Move 1 non-CLI module to packs/core (proof-of-concept)",
      "produces": [".chatelet/refactor-stub.json"],
      "consumes": ["p4-pack-core-stub"],
      "deps": ["p4-pack-core-stub"],
      "validate": [{"type": "artifact-exists", "target": ".chatelet/refactor-stub.json"}],
      "idempotent": true
    },
    "p4-acceptance-tests": {
      "id": "p4-acceptance-tests",
      "desc": "Verify all 6 acceptance criteria + 5 scenarios",
      "produces": [".chatelet/acceptance-results.json"],
      "consumes": ["p4-chatelet-status", "p4-packs-list", "p4-packs-extract", "p4-ci-gate-keep", "p4-migration-planner"],
      "deps": ["p4-chatelet-status", "p4-packs-list", "p4-packs-extract", "p4-ci-gate-keep", "p4-migration-planner"],
      "validate": [{"type": "artifact-exists", "target": ".chatelet/acceptance-results.json"}],
      "idempotent": true
    },
    "p4-chatelet-complete": {
      "id": "p4-chatelet-complete",
      "desc": "Châtelet architecture live — keep is minimal, packs discoverable",
      "produces": [".chatelet/p4-chatelet-complete.json"],
      "consumes": [".chatelet/acceptance-results.json"],
      "deps": ["p4-acceptance-tests"],
      "validate": [{"type": "artifact-exists", "target": ".chatelet/p4-chatelet-complete.json"}],
      "idempotent": true
    }
  }
}
