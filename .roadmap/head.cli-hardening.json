{
  "id": "fr-cli-hardening-001",
  "desc": "FR-CLI-HARDENING-001: CLI Integration Hardening (Exit Codes, JSON Validation, Metaflow)",
  "init": "init",
  "term": "term",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Synthetic init — start FR-CLI-HARDENING-001",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "idempotent": false
    },
    "audit-exit-codes": {
      "id": "audit-exit-codes",
      "desc": "Audit all CLI commands for correct exit codes (0/1/2/3/4 semantics)",
      "produces": [
        "reports/cli-exit-codes-audit.json",
        "src/lib/cli-exit-codes.ts"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": ["reports/cli-exit-codes-audit.json", "src/lib/cli-exit-codes.ts"]},
        {"type": "shell", "command": "grep -c 'EXIT_SUCCESS\\|EXIT_USER_ERROR\\|EXIT_SYSTEM_ERROR' src/lib/cli-exit-codes.ts"}
      ],
      "idempotent": true
    },
    "validate-json-output": {
      "id": "validate-json-output",
      "desc": "Validate all command outputs conform to JSON schema (no mixed text)",
      "produces": [
        "tests/cli/json-output.test.ts",
        "src/lib/cli-envelope.ts (instrumented)"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": "tests/cli/json-output.test.ts"},
        {"type": "shell", "command": "npm test -- json-output.test.ts"}
      ],
      "idempotent": true
    },
    "concurrent-claims-handler": {
      "id": "concurrent-claims-handler",
      "desc": "Test concurrent claim scenarios (race conditions on node completion)",
      "produces": [
        "tests/cli/concurrent-claims.test.ts",
        "src/lib/claims/claims-atomic.ts"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": ["tests/cli/concurrent-claims.test.ts", "src/lib/claims/claims-atomic.ts"]},
        {"type": "shell", "command": "npm test -- concurrent-claims.test.ts"}
      ],
      "idempotent": true
    },
    "state-corruption-detection": {
      "id": "state-corruption-detection",
      "desc": "Enhance completion doctor: detect completed.json vs head.json divergence",
      "produces": [
        "src/lib/completion/corruption-detector.ts",
        "tests/cli/completion-doctor.test.ts"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/completion/corruption-detector.ts", "tests/cli/completion-doctor.test.ts"]},
        {"type": "shell", "command": "npm test -- completion-doctor.test.ts"}
      ],
      "idempotent": true
    },
    "metaflow-instrumentation": {
      "id": "metaflow-instrumentation",
      "desc": "Wire metaflow mining into all CLI commands (--mf-run capture)",
      "produces": [
        "src/lib/metaflow/command-instrumentation.ts",
        "tests/cli/metaflow-integration.test.ts"
      ],
      "consumes": [
        "src/lib/cli-envelope.ts"
      ],
      "deps": ["validate-json-output"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/metaflow/command-instrumentation.ts", "tests/cli/metaflow-integration.test.ts"]},
        {"type": "shell", "command": "npm test -- metaflow-integration.test.ts"}
      ],
      "idempotent": true
    },
    "integration-test-suite": {
      "id": "integration-test-suite",
      "desc": "End-to-end CLI integration tests covering all scenarios",
      "produces": [
        "tests/cli/integration.test.ts",
        "reports/cli-integration-coverage.json"
      ],
      "consumes": [
        "tests/cli/json-output.test.ts",
        "tests/cli/concurrent-claims.test.ts",
        "tests/cli/completion-doctor.test.ts",
        "tests/cli/metaflow-integration.test.ts"
      ],
      "deps": ["audit-exit-codes", "validate-json-output", "concurrent-claims-handler", "state-corruption-detection", "metaflow-instrumentation"],
      "validate": [
        {"type": "artifact-exists", "target": ["tests/cli/integration.test.ts", "reports/cli-integration-coverage.json"]},
        {"type": "shell", "command": "npm test -- integration.test.ts"}
      ],
      "idempotent": true
    },
    "dogfood-on-roadmap": {
      "id": "dogfood-on-roadmap",
      "desc": "Execute roadmap commands with instrumentation enabled; validate outputs",
      "produces": [
        ".roadmap/runs/dogfood-cli/mining.json",
        "reports/dogfood-execution-report.json"
      ],
      "consumes": [
        "src/lib/metaflow/command-instrumentation.ts",
        "reports/cli-integration-coverage.json"
      ],
      "deps": ["integration-test-suite"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/runs/dogfood-cli/mining.json", "reports/dogfood-execution-report.json"]},
        {"type": "shell", "command": "jq '.commands | length > 0' reports/dogfood-execution-report.json"}
      ],
      "idempotent": true
    },
    "hardening-report": {
      "id": "hardening-report",
      "desc": "Synthesis: CLI hardening report with gaps, coverage metrics, recommendations",
      "produces": [
        "reports/CLI-HARDENING-REPORT.md",
        "reports/cli-metrics.json"
      ],
      "consumes": [
        "reports/cli-exit-codes-audit.json",
        "reports/cli-integration-coverage.json",
        "reports/dogfood-execution-report.json"
      ],
      "deps": ["dogfood-on-roadmap"],
      "validate": [
        {"type": "artifact-exists", "target": ["reports/CLI-HARDENING-REPORT.md", "reports/cli-metrics.json"]},
        {"type": "shell", "command": "grep -c 'Coverage\\|Gaps\\|Recommendation' reports/CLI-HARDENING-REPORT.md"}
      ],
      "idempotent": true
    },
    "term": {
      "id": "term",
      "desc": "Synthetic term — FR-CLI-HARDENING-001 complete",
      "produces": [],
      "consumes": [],
      "deps": ["hardening-report"],
      "validate": [],
      "idempotent": false
    }
  }
}
