{
  "id": "impl-bookend-gates",
  "desc": "Implement init intent gates — plan clarity validation at DAG entry",
  "init": "init",
  "term": "term",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Start: implement init intent gates for plan clarity",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "idempotent": true
    },

    "design-init-gate": {
      "id": "design-init-gate",
      "mode": "plan",
      "desc": "Design init intent gate: structure, evaluator logic, expansion triggers",
      "produces": [],
      "consumes": ["docs/FR-INTENT-EXPANSION.md", "src/protocol.ts"],
      "deps": ["init"],
      "validate": [{ "type": "expanded" }],
      "idempotent": false
    },

    "impl-validatePlanClarity": {
      "id": "impl-validatePlanClarity",
      "desc": "Implement validatePlanClarity() — evaluator for init gate",
      "produces": ["src/lib/validate-plan-clarity.ts"],
      "consumes": ["src/protocol.ts", "docs/FR-INTENT-EXPANSION.md"],
      "deps": ["design-init-gate"],
      "validate": [
        { "type": "artifact-exists", "path": "src/lib/validate-plan-clarity.ts" },
        { "type": "shell", "cmd": "npm test -- validate-plan-clarity 2>&1 | grep -E 'passed|failed'" }
      ],
      "idempotent": false
    },

    "impl-initGateExpansion": {
      "id": "impl-initGateExpansion",
      "desc": "Extend generateIntentExpansion() to handle plan clarity failures",
      "produces": ["src/lib/intent-expansion.ts"],
      "consumes": ["src/lib/validate-plan-clarity.ts"],
      "deps": ["impl-validatePlanClarity"],
      "validate": [
        { "type": "artifact-exists", "path": "src/lib/intent-expansion.ts" },
        { "type": "shell", "cmd": "npm test -- intent-expansion 2>&1 | grep -E 'passed|failed'" }
      ],
      "idempotent": false
    },

    "impl-detectInitGate": {
      "id": "impl-detectInitGate",
      "desc": "Modify validateDAG() — detect missing init gate, add to invariant check",
      "produces": ["src/lib/validate-dag.ts"],
      "consumes": ["src/protocol.ts"],
      "deps": ["design-init-gate"],
      "validate": [
        { "type": "artifact-exists", "path": "src/lib/validate-dag.ts" },
        { "type": "shell", "cmd": "npm test -- validate-dag 2>&1 | grep -E 'passed|failed'" }
      ],
      "idempotent": false
    },

    "impl-cliInitGate": {
      "id": "impl-cliInitGate",
      "desc": "Add CLI commands: roadmap init, roadmap create with --init-gate flag",
      "produces": ["bin/roadmap.ts"],
      "consumes": ["docs/FR-INTENT-EXPANSION.md"],
      "deps": ["impl-detectInitGate"],
      "validate": [
        { "type": "artifact-exists", "path": "bin/roadmap.ts" },
        { "type": "shell", "cmd": "npm test 2>&1 | grep -E 'Tests.*passed'" }
      ],
      "idempotent": false
    },

    "test-initGateE2E": {
      "id": "test-initGateE2E",
      "desc": "E2E tests: vague plan → init gate fails → expansion clarifies → gates pass",
      "produces": ["tests/init-gate-e2e.test.ts"],
      "consumes": ["src/lib/validate-plan-clarity.ts", "src/lib/intent-expansion.ts"],
      "deps": ["impl-initGateExpansion", "impl-cliInitGate"],
      "validate": [
        { "type": "artifact-exists", "path": "tests/init-gate-e2e.test.ts" },
        { "type": "shell", "cmd": "npm test -- init-gate-e2e 2>&1 | grep -E 'passed|failed'" }
      ],
      "idempotent": false
    },

    "test-bookendInvariant": {
      "id": "test-bookendInvariant",
      "desc": "Tests: DAG cannot execute without both init + terminal gates, validateDAG enforces",
      "produces": ["tests/bookend-gates.test.ts"],
      "consumes": ["src/lib/validate-dag.ts"],
      "deps": ["impl-detectInitGate"],
      "validate": [
        { "type": "artifact-exists", "path": "tests/bookend-gates.test.ts" },
        { "type": "shell", "cmd": "npm test -- bookend-gates 2>&1 | grep -E 'passed|failed'" }
      ],
      "idempotent": false
    },

    "integration-bookendGates": {
      "id": "integration-bookendGates",
      "desc": "Integration: init + terminal gates both enforced, DAG refinement loop complete",
      "produces": [],
      "consumes": [],
      "deps": ["test-initGateE2E", "test-bookendInvariant"],
      "validate": [
        { "type": "shell", "cmd": "npm test 2>&1 | tail -5" },
        { "type": "shell", "cmd": "npx tsc --noEmit" }
      ],
      "idempotent": true
    },

    "doc-bookendPattern": {
      "id": "doc-bookendPattern",
      "desc": "Documentation: bookend gates pattern, examples, user guide",
      "produces": ["docs/PATTERN-BOOKEND-GATES.md"],
      "consumes": ["docs/FR-INTENT-EXPANSION.md"],
      "deps": ["integration-bookendGates"],
      "validate": [
        { "type": "artifact-exists", "path": "docs/PATTERN-BOOKEND-GATES.md" },
        { "type": "shell", "cmd": "grep -q 'init intent gate' docs/PATTERN-BOOKEND-GATES.md" }
      ],
      "idempotent": false
    },

    "term": {
      "id": "term",
      "desc": "Done: init intent gates implemented, bookend invariant enforced, DAG closure complete",
      "produces": [],
      "consumes": [],
      "deps": ["doc-bookendPattern"],
      "validate": [
        {
          "type": "intent",
          "statement": "Init and terminal intent gates both mandatory, enforced by validateDAG(), enabled by expandOnFail recursion",
          "confidence": 0.95,
          "evaluator": "self",
          "expandOnFail": true
        }
      ],
      "idempotent": true
    }
  }
}
