{
  "id": "roadmap-hardening-001",
  "desc": "Fix roadmap state sync failures: auto-recovery, pre-flight validation, atomic metadata, artifact gates",
  "init": "headsha-recovery",
  "term": "hardening-complete",
  "nodes": {
    "headsha-recovery": {
      "id": "headsha-recovery",
      "desc": "Auto-detect and recover from headSha mismatches without manual intervention",
      "produces": [
        "src/lib/roadmap/headsha-recovery.ts",
        "tests/headsha-recovery.test.ts"
      ],
      "consumes": [
        ".roadmap/head.json",
        ".git/HEAD"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/roadmap/headsha-recovery.ts"},
        {"type": "build-produces", "path": "src/lib/roadmap/headsha-recovery.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "preflight-validation": {
      "id": "preflight-validation",
      "desc": "Pre-flight checks before roadmap operations: state coherence, artifact existence, typecheck",
      "produces": [
        "src/lib/roadmap/preflight-validator.ts",
        "tests/preflight-validator.test.ts"
      ],
      "consumes": [
        ".roadmap/head.json",
        "src/lib/roadmap/headsha-recovery.ts"
      ],
      "deps": ["headsha-recovery"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/roadmap/preflight-validator.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    },
    "trail-management": {
      "id": "trail-management",
      "desc": "Atomic trail.jsonl handling: auto-gitignore or auto-commit without manual friction",
      "produces": [
        "src/lib/roadmap/trail-manager.ts",
        "tests/trail-manager.test.ts",
        ".gitignore.trail"
      ],
      "consumes": [
        ".roadmap/trail.jsonl"
      ],
      "deps": ["headsha-recovery"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/roadmap/trail-manager.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    },
    "dag-switching": {
      "id": "dag-switching",
      "desc": "Proper CLI for DAG switching (no symlinks): roadmap switch <dag-id>",
      "produces": [
        "src/lib/roadmap/dag-switcher.ts",
        "tests/dag-switcher.test.ts"
      ],
      "consumes": [
        ".roadmap/head.*.json",
        "src/lib/roadmap/headsha-recovery.ts"
      ],
      "deps": ["headsha-recovery"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/roadmap/dag-switcher.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    },
    "artifact-gates": {
      "id": "artifact-gates",
      "desc": "Validation gates: artifact existence, typecheck, schema compliance on completion",
      "produces": [
        "src/lib/roadmap/artifact-gates.ts",
        "tests/artifact-gates.test.ts"
      ],
      "consumes": [
        "src/lib/roadmap/preflight-validator.ts"
      ],
      "deps": ["preflight-validation"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/roadmap/artifact-gates.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 3
    },
    "integration-tests": {
      "id": "integration-tests",
      "desc": "Integration tests: verify headSha recovery, atomic commits, DAG switching all work together",
      "produces": [
        "tests/roadmap-hardening-integration.test.ts",
        "hardening-validation.json"
      ],
      "consumes": [
        "src/lib/roadmap/headsha-recovery.ts",
        "src/lib/roadmap/preflight-validator.ts",
        "src/lib/roadmap/trail-manager.ts",
        "src/lib/roadmap/dag-switcher.ts",
        "src/lib/roadmap/artifact-gates.ts"
      ],
      "deps": ["artifact-gates", "dag-switching", "trail-management"],
      "validate": [
        {"type": "artifact-exists", "path": "tests/roadmap-hardening-integration.test.ts"},
        {"type": "artifact-exists", "path": "hardening-validation.json"}
      ],
      "idempotent": false,
      "mode": "execute",
      "level": 4
    },
    "hardening-complete": {
      "id": "hardening-complete",
      "desc": "Terminal: all roadmap state sync issues resolved, system hardened",
      "produces": [],
      "consumes": [
        "hardening-validation.json"
      ],
      "deps": ["integration-tests"],
      "validate": [
        {"type": "artifact-exists", "path": "hardening-validation.json"}
      ],
      "idempotent": false,
      "mode": "execute",
      "level": 5
    }
  }
}
